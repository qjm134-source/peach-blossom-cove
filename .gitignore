# ============================================
# 幻境漫游 WonderRealm - Git忽略配置
# ============================================

# 依赖目录
node_modules/
.pnpm-store/

# 构建输出
**/dist/
**/build/
**/out/

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db

# IDE / 编辑器
.vscode/
.idea/
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# 环境变量（敏感信息）
.env
.env.local
.env.*.local

# 备份文件
*.bak
*.backup
*.orig

# 压缩包
*.zip
*.rar
*.7z
*.tar.gz

# 测试覆盖率
coverage/
.nyc_output/
