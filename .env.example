# ============================================
# 幻境漫游 WonderRealm 环境变量配置
# ============================================

# 运行环境: development | production
NODE_ENV=development

# HTTP API 端口
PORT=3000

# WebSocket 端口 (与HTTP共用服务器时无需设置)
WS_PORT=8080

# 允许跨域来源
CORS_ORIGIN=*

# 最大同时在线玩家数
MAX_PLAYERS=100

# 日志级别: debug | info | warn | error
LOG_LEVEL=info
